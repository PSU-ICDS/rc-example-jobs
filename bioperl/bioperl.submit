#!/bin/bash

#### Scheduler Directives ####
#SBATCH --account=open
#SBATCH --partition=basic
#SBATCH --nodes=1
#SBATCH --ntasks-per-node=1
#SBATCH --time=01:00:00
#SBATCH --mem=4G
#SBATCH --output=bioperl_%j.out
#SBATCH --error=bioperl_%j.err

module unuse /storage/icds/sw8/modulefiles/Core
module use /storage/icds/sw8/modulefiles_26/Core
module load bioperl/1.7.8

# set up user perl library
perl -I$HOME/perl5/lib/perl5 -Mlocal::lib

# run bioperl script
perl -w script.pl
