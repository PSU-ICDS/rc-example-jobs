#!/bin/bash
#SBATCH --nodes=1
#SBATCH --ntasks-per-node=1
#SBATCH --time=10:00
#SBATCH --mem=10GB
#SBATCH --partition=basic
#SBATCH --account=open
#SBATCH --output=matlab.%j.out
#SBATCH --error=matlab.%j.err

# Load matlab
module purge
module load matlab/R2022a

# Run the job itself 
matlab -batch "mygnrun(1000)"
